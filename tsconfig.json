{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "skipLibCheck": true
  },
  "include": [
    "playwright.config.ts",
    "e2e/playwright.config.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
